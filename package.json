{
	"name": "@canva/n8n-nodes-canva",
	"version": "0.1.2",
	"description": "Canva API integration for n8n. Create, edit, and export designs, folders, and more.",
	"license": "MIT",
	"homepage": "https://github.com/canva-sdks/n8n-nodes-canva#readme",
	"keywords": [
		"n8n-community-node-package",
		"canva",
		"design"
	],
	"author": {
		"name": "Canva",
		"email": "integrations-support@canva.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/canva-sdks/n8n-nodes-canva.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "N8N_EDITOR_BASE_URL=http://127.0.0.1:5678 n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"prettier": "prettier --check .",
		"prettier:fix": "prettier --write .",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/CanvaOAuth2Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/Canva/Canva.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "^9.39.4",
		"prettier": "3.6.2",
		"release-it": "^20.2.1",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"engines": {
		"node": ">=24"
	}
}
